{
  "name": "yingyue-photo-pickup-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "影约云客户取片 H5 / 微信小程序客户端",
  "scripts": {
    "dev:h5": "uni",
    "dev:h5:api": "uni --mode api --host 127.0.0.1 --port 5174",
    "dev:mp-weixin": "uni -p mp-weixin --mode api",
    "dev:mp-toutiao": "uni -p mp-toutiao --mode api",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin --mode api",
    "build:mp-toutiao": "uni build -p mp-toutiao --mode api",
    "test": "node --test tests/*.test.cjs",
    "test:h5": "node tests/h5-browser-smoke.cjs",
    "typecheck": "vue-tsc --noEmit",
    "check:file-size": "node scripts/check-file-size.mjs"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4060620250520001",
    "@dcloudio/uni-h5": "3.0.0-4060620250520001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-4060620250520001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4060620250520001",
    "@dcloudio/uni-ui": "1.5.8",
    "vue": "3.5.16"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.15",
    "@dcloudio/vite-plugin-uni": "3.0.0-4060620250520001",
    "@vue/tsconfig": "0.7.0",
    "playwright": "^1.60.0",
    "sass": "1.89.1",
    "typescript": "5.8.3",
    "vite": "5.4.21",
    "vue-tsc": "2.2.10"
  }
}
