# 页面标题
VITE_APP_TITLE = 影约云企业相馆管理系统
VITE_APP_LOGO_TITLE = 影约云

# 环境配置：development / production
VITE_APP_ENV = 'development'
VITE_APP_BASE_API = '/dev-api'
VITE_APP_CONTEXT_PATH = '/'

# 监控与任务控制台
VITE_APP_MONITOR_ADMIN = 'http://localhost:9090/admin/applications'
VITE_APP_SNAILJOB_ADMIN = 'http://localhost:8800/snail-job'

VITE_APP_PORT = 80

# 客户取片 H5 入口。为空时后台只生成小程序取片说明；正式 H5 上线后填如 https://photo.example.com
VITE_APP_PHOTO_PICKUP_H5_URL = ''

# 正式后端公网入口，用于后台复制 OSS/取片生产预检命令。
VITE_APP_PUBLIC_API_URL = 'https://api.evanshine.me'

# 接口加密：真实密钥必须按环境单独生成，禁止把生产私钥提交到 GitHub。
VITE_APP_ENCRYPT = false
VITE_APP_RSA_PUBLIC_KEY = 'replace-with-backend-matching-public-key'
VITE_APP_RSA_PRIVATE_KEY = 'replace-with-frontend-private-key'

# 客户端 id
VITE_APP_CLIENT_ID = 'replace-with-client-id'

VITE_APP_WEBSOCKET = false
VITE_APP_SSE = true
