DB_URL=jdbc:postgresql://127.0.0.1:5432/yingyue_cloud?useUnicode=true&characterEncoding=utf8&sslmode=disable&reWriteBatchedInserts=true
DB_DRIVER=org.postgresql.Driver
DB_USERNAME=postgres
DB_PASSWORD=change-before-production
REDIS_PASSWORD=change-before-production
SNAIL_JOB_TOKEN=change-before-production
API_DECRYPT_ENABLED=false
API_DECRYPT_PUBLIC_KEY=replace-with-response-encryption-public-key
API_DECRYPT_PRIVATE_KEY=replace-with-request-decryption-private-key
YY_CLIENT_PHOTO_TOKEN_SECRET=replace-with-random-32-plus-char-client-photo-token-secret
YY_CLIENT_ORDER_TOKEN_SECRET=replace-with-random-32-plus-char-client-order-token-secret
YY_CLIENT_PUBLIC_TOKEN_SECRET=replace-with-random-32-plus-char-client-public-token-secret
YY_CLIENT_ORDER_PUBLIC_BASE_URL=https://photo.evanshine.me
YY_PUBLIC_API_BASE_URL=https://api.evanshine.me
YY_CLIENT_PHOTO_STREAM_BASE_URL=https://api.evanshine.me
# 正式 OSS 必须保持私有；客户图片只走后端签名 URL 或 /client/photo/assets/{assetId}/stream
YY_OSS_PUBLIC_READ=false

# 客户取片平台手机号授权：默认关闭；正式启用前先在微信/抖音后台配置合法域名并用真机验证。
YY_CLIENT_PHOTO_PHONE_AUTH_ENABLED=false
YY_CLIENT_PHOTO_PHONE_AUTH_BASE_URL=
WECHAT_MINI_APP_ID=replace-with-wechat-miniapp-id
WECHAT_MINI_APP_SECRET=replace-with-wechat-miniapp-secret
WECHAT_MINI_APP_ACCESS_TOKEN=
DOUYIN_MINI_APP_ACCESS_TOKEN=
DOUYIN_MINI_APP_PHONE_PATH=

# 抖音开放平台沙盒参数：只填本地/服务器环境变量，不提交真实值
DOUYIN_CLIENT_KEY=replace-with-sandbox-client-key
DOUYIN_CLIENT_SECRET=replace-with-sandbox-client-secret
DOUYIN_SERVICE_ID=replace-with-service-id
DOUYIN_SERVICE_MODE_ID=replace-with-service-mode-id
DOUYIN_TEST_OPEN_ID=replace-with-test-open-id
# 沙盒应用用 open-sandbox，正式应用再切回 https://open.douyin.com
DOUYIN_BASE_URL=https://open-sandbox.douyin.com

# 抖音生活服务/团购订单联调参数：与上面的服务市场小程序沙盒不是一套业务
DOUYIN_LIFE_BASE_URL=https://open.douyin.com
DOUYIN_LIFE_CLIENT_KEY=replace-with-local-life-client-key
DOUYIN_LIFE_CLIENT_SECRET=replace-with-local-life-client-secret
DOUYIN_LIFE_ACCOUNT_ID=replace-with-merchant-account-id
DOUYIN_LIFE_POI_ID=replace-with-test-or-production-poi-id
DOUYIN_LIFE_REQUIRE_SIGNATURE=true
DOUYIN_LIFE_REFUND_APPLY_MODE=processing
DOUYIN_LIFE_REFUND_REJECT_REASON=replace-with-refund-reject-reason
DOUYIN_LIFE_ORDER_ID=replace-with-test-order-id
DOUYIN_LIFE_OUT_ORDER_NO=replace-with-test-out-order-no
DOUYIN_LIFE_OPEN_ID=replace-with-buyer-open-id
DOUYIN_LIFE_ORDER_STATUS=replace-with-order-status
